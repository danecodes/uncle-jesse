<?xml version="1.0" encoding="utf-8" ?>
<component name="VideoScreen" extends="Group">
    <interface>
        <field id="content" type="node" onChange="onContentChange" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/screens/VideoScreen.brs" />

    <children>
        <Video
            id="videoPlayer"
            width="1280"
            height="720"
            enableUI="true" />

        <Label
            id="videoTitle"
            translation="[40, 20]"
            font="font:MediumBoldSystemFont"
            color="0xffffffff" />
    </children>
</component>
