{
  "name": "uncle-jesse",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "uncle-jesse": "./bin/uncle-jesse.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@danecodes/roku-ecp": "0.4.2",
    "@danecodes/uncle-jesse-core": "workspace:*",
    "@danecodes/uncle-jesse-roku": "workspace:*",
    "@danecodes/uncle-jesse-test": "workspace:*",
    "chalk": "^5.4.0",
    "commander": "^13.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
